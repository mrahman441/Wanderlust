<% layout('./layouts/boilerplate') -%>

    <body>
        <h3 class="text-left mb-3 mt-3 text-dark">All Listings</h3>

        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4 mb-5">
            <% listings.forEach(function(listing) { %>
                <div class="col">
                    <a class="text-decoration-none" href="/listings/<%= listing.id %>">
                        <div class="card h-100">
                            <img src="<%= listing.image %>" class="card-img-top" alt="...">
                            <div class="card-img-overlay"></div>
                            <div class="card-body">
                                <p class="card-text">
                                    <b>
                                        <%= listing.title %>
                                    </b> <br>
                                    <%= "$" + listing.price.toLocaleString("en-US") + "/night" %>
                                </p>
                            </div>
                        </div>
                    </a>
                </div>
                <% }); %>
        </div>
    </body>