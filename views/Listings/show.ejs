<% layout('./layouts/boilerplate') -%>
    <script>
        let mapToken = '<%= process.env.MAP_TOKEN %>';
        const coordinates = <%- JSON.stringify(listing.geometry) %>;
        const popUpLocation = "<%= listing.location %>, <%= listing.country %>";
    </script>

    <div class="row mt-3 mb-5">
        <div class="col-12 col-md-8 offset-md-2">
            <div class="d-flex justify-content-between align-items-center mb-0">
                <h3 class="mb-0">
                    <%= listing.title %>
                </h3>
                <% if(currentUser && currentUser._id.equals(listing.owner._id)) { %>
                    <div class="d-flex gap-2 mt-2">
                        <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark btn-sm">Edit</a>
                        <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST">
                            <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                        </form>
                    </div>
                    <% } %>
            </div>
            <!-- owner -->
            <p class="mb-3 text-muted fst-italic">
                Owned by @<%= listing.owner.username %>
            </p>

            <div class="card mb-3">
                <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="<%= listing.title %>">
                <div class="card-body">
                    <p class="card-text">
                        <%= listing.description %>
                    </p>
                    <p class="card-text">
                        <strong>Price:</strong> $<%= listing.price.toLocaleString("en-US") + "/Night" %>
                    </p>
                    <p class="card-text">
                        <strong>Location:</strong>
                        <%= listing.location %>, <%= listing.country %>
                    </p>
                </div>
            </div>
            <hr>
            <!-- Reviews Section -->
            <div class="mt-3">
                <h4 class="mb-3">Leave a Review</h4>
                <form action="/listings/<%= listing._id %>/reviews" method="POST" class="needs-validation" novalidate>
                    <fieldset class="starability-slot mb-3">
                        <legend>Rating</legend>
                        <input type="radio" id="no-rate" class="input-no-rate" name="review[ratings]" value="1" checked
                            aria-label="No rating." />
                        <input type="radio" id="first-rate1" name="review[ratings]" value="1" />
                        <label for="first-rate1" title="Terrible">1 star</label>
                        <input type="radio" id="first-rate2" name="review[ratings]" value="2" />
                        <label for="first-rate2" title="Not good">2 stars</label>
                        <input type="radio" id="first-rate3" name="review[ratings]" value="3" />
                        <label for="first-rate3" title="Average">3 stars</label>
                        <input type="radio" id="first-rate4" name="review[ratings]" value="4" />
                        <label for="first-rate4" title="Very good">4 stars</label>
                        <input type="radio" id="first-rate5" name="review[ratings]" value="5" />
                        <label for="first-rate5" title="Amazing">5 stars</label>
                    </fieldset>
                    <div class="mb-3">
                        <label for="reviewText" class="form-label">Your Review</label>
                        <textarea class="form-control" id="reviewText" name="review[comments]" rows="3"
                            required></textarea>
                        <div class="valid-feedback">
                            Looks good!
                        </div>
                        <div class="invalid-feedback">
                            Please provide a review comment.
                        </div>
                    </div>

                    <button type="submit" class="btn btn-dark">Submit Review</button>
                </form>
            </div>
            <hr>
            <!-- Reviews List -->
            <div class="mt-5">
                <h4 class="mb-3">Total Reviews - <%= listing.reviews.length %>
                </h4>
                <% if (listing.reviews.length===0) { %>
                    <div class="alert alert-info" role="alert">
                        <i class="fas fa-info-circle"></i> No reviews yet. Be the first to review!
                    </div>
                    <% } else { %>
                        <div class="row g-3">
                            <% listing.reviews.forEach(review=> { %>
                                <div class="col-md-4">
                                    <div class="card border h-100 p-3">
                                        <div class="card-body">
                                            <div class="d-flex justify-content-between align-items-start mb-2">
                                                <h5 class="card-title mb-0">
                                                    @<%= review.author.username %>
                                                </h5>
                                                <% if(currentUser && currentUser._id.equals(review.author._id)) { %>
                                                    <form
                                                        action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                                                        method="POST" class="d-inline">
                                                        <button type="submit"
                                                            class="btn btn-sm text-danger fw-bold p-0">Delete</button>
                                                    </form>
                                                    <% } %>
                                            </div>
                                            <div class="starability-result mb-2" data-rating="<%= review.ratings %>"
                                                style="transform: scale(0.5); transform-origin: left; margin-top: -5px; margin-bottom: -5px;">
                                                Rated: <%= review.ratings %> stars
                                            </div>
                                            <p class="card-text">
                                                <%= review.comments %>
                                            </p>

                                        </div>
                                    </div>
                                </div>
                                <% }) %>
                        </div>
                        <% } %>
            </div>

            <!-- map -->
            <div class="mt-5">
                <h4 class="mb-3">Location Map</h4>
                <div id="map"></div>
            </div>
        </div>
    </div>
    <script src="/js/map.js"> </script>