<nav class="navbar navbar-expand-lg bg-body-light shadow-xl border-bottom sticky-top">
    <div class="container-fluid d-flex align-items-center justify-content-between">
        <!-- Left: Brand -->
        <div class="d-flex align-items-center" style="flex: 1;">
            <a class="navbar-brand" href="/listings"><i class="fa-regular fa-compass"></i></a>
            <a class="brand-name text-decoration-none text-dark" href="/listings">Wanderlust</a>
        </div>

        <!-- Center: Search Bar for Desktop -->
        <div class="d-none d-lg-flex justify-content-center" style="flex: 1; max-width: 500px;">
            <form class="d-flex w-100 align-items-center gap-2" role="search">
                <input class="form-control" type="search" placeholder="Search destinations" aria-label="Search"
                    style="border-radius: 999px; border: 1px solid #dee2e6; padding: 0.5rem 1.25rem;">
                <button class="btn d-flex align-items-center gap-2 text-white text-nowrap" type="submit"
                    style="background-color: #ff385c; border-radius: 999px; padding: 0.5rem 1.25rem; border: none;">
                    <i class="fa-solid fa-magnifying-glass"></i> Search
                </button>
            </form>
        </div>

        <!-- Right: Nav Items (Desktop) -->
        <div class="collapse navbar-collapse d-none d-lg-flex justify-content-end" id="navbarNavAltMarkup"
            style="flex: 1;">
            <div class="navbar-nav">
                <a class="nav-link" href="/listings">Explore</a>
                <a class="nav-link" href="/listings/new">Add your home</a>
                <% if(!currentUser){ %>
                    <a class="nav-link text-bold" href="/auth/login">Login</a>
                    <% } else { %>
                        <a class="nav-link disabled" href="">|</a>
                        <a class="nav-link text-dark text-bold" href="/auth/profile">
                            <%= currentUser.username %>
                        </a>
                        <% } %>
            </div>
        </div>
    </div>
</nav>

<!-- Mobile Search Panel (slide up above tab bar) -->
<div id="mobileSearchPanel" class="d-lg-none"
    style="display:none !important; position:fixed; bottom:3.5rem; left:0; right:0; z-index:1029; background:#fff; border-top:1px solid #dee2e6; padding:0.75rem 1rem;">
    <form class="d-flex align-items-center gap-2" role="search">
        <input class="form-control" type="search" placeholder="Search destinations" aria-label="Search"
            style="border-radius:999px; border:1px solid #dee2e6; padding:0.45rem 1rem;">
        <button class="btn d-flex align-items-center gap-1 text-white text-nowrap" type="submit"
            style="background-color:#ff385c; border-radius:999px; padding:0.45rem 1.1rem; border:none;">
            <i class="fa-solid fa-magnifying-glass"></i> Search
        </button>
    </form>
</div>

<!-- Bottom Tab Nav for Mobile -->
<nav class="mobile-bottom-nav d-lg-none">
    <a href="/listings" class="mobile-bottom-nav-item">
        <i class="fa-solid fa-list"></i>
        <span>Explore</span>
    </a>
    <button type="button" class="mobile-bottom-nav-item border-0 bg-transparent" id="mobileSearchToggle">
        <i class="fa-solid fa-magnifying-glass"></i>
        <span>Search</span>
    </button>
    <a href="/listings/new" class="mobile-bottom-nav-item">
        <i class="fa-solid fa-plus"></i>
        <span>Add home</span>
    </a>
    <% if(!currentUser){ %>
        <a href="/auth/login" class="mobile-bottom-nav-item">
            <i class="fa-solid fa-right-to-bracket"></i>
            <span>Login</span>
        </a>
        <% } else { %>
            <a href="/auth/profile" class="mobile-bottom-nav-item">
                <i class="fa-solid fa-user"></i>
                <span>
                    <%= currentUser.username %>
                </span>
            </a>
            <% } %>
</nav>

<script>
    const toggle = document.getElementById('mobileSearchToggle');
    const panel = document.getElementById('mobileSearchPanel');
    toggle.addEventListener('click', () => {
        panel.classList.toggle('open');
        if (panel.classList.contains('open')) {
            panel.querySelector('input').focus();
        }
    });
    // close panel when clicking outside
    document.addEventListener('click', (e) => {
        if (!panel.contains(e.target) && e.target !== toggle && !toggle.contains(e.target)) {
            panel.classList.remove('open');
        }
    });
</script>